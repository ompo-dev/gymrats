{
  "name": "gymrats",
  "version": "36.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --prefix apps/web run build",
    "build:api": "npm --prefix apps/api run build",
    "build:worker": "npm --prefix apps/worker run build",
    "build:cron": "npm --prefix apps/cron run build",
    "build:node": "npm --prefix apps/web run build:node",
    "dev": "npm --prefix apps/web run dev",
    "dev:api-app": "npm --prefix apps/api run dev",
    "dev:worker": "npm --prefix apps/worker run dev",
    "dev:next": "npm --prefix apps/web run dev:next",
    "dev:webpack": "npm --prefix apps/web run dev:webpack",
    "dev:server": "npm --prefix apps/web run dev:server",
    "dev:all": "npm --prefix apps/web run dev:all",
    "dev:api": "npm --prefix apps/web run dev:api",
    "dev:full": "npm --prefix apps/web run dev:full",
    "stack": "node scripts/stack.mjs",
    "stack:init": "node scripts/stack.mjs init",
    "stack:doctor": "node scripts/stack.mjs doctor",
    "stack:build": "node scripts/stack.mjs build",
    "stack:migrate": "node scripts/stack.mjs migrate",
    "stack:up": "node scripts/stack.mjs up --build",
    "stack:down": "node scripts/stack.mjs down",
    "stack:restart": "node scripts/stack.mjs restart",
    "stack:logs": "node scripts/stack.mjs logs",
    "stack:status": "node scripts/stack.mjs ps",
    "stack:monitor": "node scripts/stack.mjs monitor",
    "stack:update": "node scripts/stack.mjs update",
    "stack:cron": "node scripts/stack.mjs cron",
    "stack:dev:up": "node scripts/stack.mjs up --dev --build",
    "stack:dev:down": "node scripts/stack.mjs down --dev",
    "migration:apply": "node apps/web/scripts/migration/run-stack-migrations.mjs --all",
    "migration:dry-run": "node apps/web/scripts/migration/run-stack-migrations.mjs --all --dry-run",
    "migration:status": "node apps/web/scripts/migration/run-stack-migrations.mjs --list",
    "migration:apply:prisma": "node apps/web/scripts/migration/apply-prisma-migrations.mjs",
    "migration:create": "node apps/web/scripts/migration/create-prisma-migration.mjs",
    "migration:create:prisma": "node apps/web/scripts/migration/create-prisma-migration.mjs",
    "migration:status:prisma": "node apps/web/scripts/migration/prisma-migration-status.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:staged": "biome check --staged",
    "lint:eslint": "eslint .",
    "check:frontend-boundary": "node scripts/check-frontend-boundary.mjs",
    "format": "biome format --write .",
    "start": "npm --prefix apps/web run start",
    "start:api": "npm --prefix apps/api run start",
    "start:worker": "npm --prefix apps/worker run start",
    "start:cron": "npm --prefix apps/cron run start",
    "verify:split": "npm run check:frontend-boundary && npm run build:api && npm run build:worker && npm run build:cron",
    "generate:openapi": "npm --prefix apps/web run generate:openapi",
    "generate:api": "npm --prefix apps/web run generate:api",
    "generate:secret": "npm --prefix apps/web run generate:secret",
    "generate:icons": "npm --prefix apps/web run generate:icons",
    "version:sync": "npm --prefix apps/web run version:sync",
    "postinstall": "npx prisma generate --schema packages/db/prisma/schema.prisma"
  },
