    "nodemailer": "^7.0.12",
    "nuqs": "^2.8.2",
    "pg": "^8.16.3",
    "pino": "^9.6.0",
    "prisma": "^6.19.0",
    "react": "^19.2.1",
    "react-day-picker": "9.8.0",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.60.0",
